# Parakram Backend — Environment Variables (Vidyuthlabs)
# Copy to .env and fill in values. NEVER commit .env to git.

# ─── Supabase (REQUIRED in production) ──────────────────────────────────────
# Database URL: Supabase Dashboard → Settings → Database → Connection String (URI)
# Use the pooler URL for best performance:
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# JWT Secret: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Your Supabase project URL (used by frontend, not backend)
# SUPABASE_URL=https://kuidfmnuoarqpkciugrx.supabase.co

# ─── LLM — pick ONE option ───────────────────────────────────────────────────
# The backend is cloud-hosted and serves web + Android clients.
# Priority: OpenRouter → Anthropic → LLM_BASE_URL (self-hosted only)

# Option 1 (PRIMARY): OpenRouter — one key, 100+ models, pay-per-token
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
# Default model if not set: openai/gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Option 2: Anthropic Claude (prompt caching cuts costs ~70% on repeated calls)
# https://console.anthropic.com/api-keys
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Option 3: Self-hosted backend only — any OpenAI-compatible endpoint
# (Ollama, Groq, Mistral, LM Studio — only useful if YOU host the backend)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# ─── Stripe Billing (Phase 2B) ─────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SIGNING_SECRET

# Price IDs — create in Stripe dashboard → Products → Add Price
STRIPE_PRICE_HOBBY=price_YOUR_HOBBY_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_ID

# ─── Server ─────────────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:8400
PLAYGROUND_DIR=../playground

# ─── Push Notifications ─────────────────────────────────────────────────────
# FCM (Android): Firebase Console → Project Settings → Cloud Messaging → Server key
FCM_SERVER_KEY=AAAA_YOUR_FCM_SERVER_KEY_HERE

# APNs (iOS): Apple Developer → Certificates, IDs & Profiles → Keys
APNS_KEY_ID=YOUR_KEY_ID_HERE
APNS_TEAM_ID=YOUR_TEAM_ID_HERE
# PEM-encoded ES256 private key (AuthKey_*.p8 file contents, all on one line with \n)
APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----
APNS_BUNDLE_ID=com.vidyuthlabs.parakram

# ─── Email (password reset, welcome) ─────────────────────────────────────────
# SendGrid: https://app.sendgrid.com/settings/api_keys
# Leave unset in dev — emails will be printed to the log instead.
SENDGRID_API_KEY=SG.YOUR_SENDGRID_KEY_HERE
EMAIL_FROM=noreply@vidyuthlabs.co.in

# ─── Logging ────────────────────────────────────────────────────────────────
RUST_LOG=parakram_backend=info,tower_http=info
